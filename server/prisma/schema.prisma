// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  password String
  role         Role     @default(EMPLOYEE)
  fullName     String
  nickname     String
  phoneNumber  String
  dateOfBirth  DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  repairs      Repair[]
}

enum Role {
  EMPLOYEE
  ADMIN
}

model Repair {
  id            Int           @id @default(autoincrement())
  description   String?
  totalPrice    Int
  completedAt   DateTime?
  status        RepairStatus  @default(IN_PROGRESS)
  paymentMethod PaymentMethod @default(CASH)
  paidAt        DateTime?
  source        RepairSource  @default(GENERAL)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  userId        Int
  user          User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  vehicleId     Int
  vehicle       Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  customerId    Int?
  customer      Customer?     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  repairItems   RepairItem[]
}

enum RepairStatus {
  IN_PROGRESS
  COMPLETED
  PAID
}

enum RepairSource {
  GENERAL
  SUSPENSION
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
}

model Vehicle {
  id             Int           @id @default(autoincrement())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  licensePlateId Int?          @unique
  licensePlate   LicensePlate? @relation(fields: [licensePlateId], references: [id], onDelete: Restrict)
  vehicleBrandId Int
  vehicleBrand   VehicleBrand  @relation(fields: [vehicleBrandId], references: [id], onDelete: Restrict)
  repairs        Repair[]
}

model VehicleBrand {
  id       Int       @id @default(autoincrement())
  brand    String
  model    String
  vehicles Vehicle[]

  @@unique([brand, model])
}

model LicensePlate {
  id        Int      @id @default(autoincrement())
  plate     String
  province  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  vehicle   Vehicle?

  @@unique([plate, province])
}

model Customer {
  id          Int      @id @default(autoincrement())
  fullName    String?
  address     String?
  phoneNumber String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  repairs     Repair[]
}

model RepairItem {
  id         Int      @id @default(autoincrement())
  customName String?
  side       String?
  unitPrice  Int
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  repairId   Int
  repair     Repair   @relation(fields: [repairId], references: [id], onDelete: Cascade)
  partId     Int?
  part       Part?    @relation(fields: [partId], references: [id], onDelete: SetNull)
  serviceId  Int?
  service    Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
}

model Part {
  id                 Int          @id @default(autoincrement())
  partNumber         String       @unique
  brand              String
  name               String
  costPrice          Int
  sellingPrice       Int
  unit               String
  stockQuantity      Int
  minStockLevel      Int
  typeSpecificData   Json?
  compatibleVehicles Json?
  publicId           String?
  secureUrl          String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  categoryId         Int
  category           Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  repairItems        RepairItem[]
}

model Service {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  price       Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  categoryId  Int
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  repairItems RepairItem[]
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  parts    Part[]
  services Service[]
}

model Employee {
  id          Int          @id @default(autoincrement())
  zkUserId    String       @unique
  nickname    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attendances Attendance[]
}

model Attendance {
  id         Int       @id @default(autoincrement())
  status     String
  scanTime   DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  employeeId Int?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: Restrict)
}
