// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  repairs   Repair[]
}

enum Role {
  EMPLOYEE
  ADMIN
}

model Customer {
  id          Int      @id @default(autoincrement())
  name        String?
  address     String?
  phoneNumber String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  repairs     Repair[]
}

model VehicleModel {
  id        Int       @id @default(autoincrement())
  brand     String
  model     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  vehicles  Vehicle[]

  @@unique([brand, model])
}

model LicensePlate {
  id          Int      @id @default(autoincrement())
  plateNumber String
  province    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vehicle     Vehicle?

  @@unique([plateNumber, province])
}

model Vehicle {
  id             Int           @id @default(autoincrement())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  licensePlate   LicensePlate? @relation(fields: [licensePlateId], references: [id], onDelete: Cascade)
  licensePlateId Int?          @unique
  vehicleModel   VehicleModel  @relation(fields: [vehicleModelId], references: [id], onDelete: Restrict)
  vehicleModelId Int
  repairs        Repair[]
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  parts     Part[]
  services  Service[]
}

model Part {
  id                 Int          @id @default(autoincrement())
  partNumber         String       @unique
  brand              String
  name               String
  costPrice          Int?
  sellingPrice       Int
  unit               String
  stockQuantity      Int
  minStockLevel      Int
  attributes         Json?
  compatibleVehicles Json?
  publicId           String?
  secureUrl          String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  category           Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  categoryId         Int
  repairItems        RepairItem[]
}

model Service {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  price       Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  categoryId  Int
  repairItems RepairItem[]
}

model Repair {
  id            Int           @id @default(autoincrement())
  description   String?
  totalPrice    Int
  type          RepairType    @default(GENERAL)
  status        RepairStatus  @default(IN_PROGRESS)
  completedAt   DateTime?
  paymentMethod PaymentMethod @default(CASH)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId        Int
  vehicle       Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  vehicleId     Int
  customer      Customer?     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  customerId    Int?
  repairItems   RepairItem[]
}

enum RepairType {
  GENERAL
  SUSPENSION
}

enum RepairStatus {
  IN_PROGRESS
  COMPLETED
  PAID
}

enum PaymentMethod {
  CASH
  QR_CODE
  CREDIT_CARD
}

model RepairItem {
  id          Int      @id @default(autoincrement())
  partName    String?
  serviceName String?
  customName  String?
  side        Side?
  unitPrice   Int
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  repair      Repair   @relation(fields: [repairId], references: [id], onDelete: Cascade)
  repairId    Int
  part        Part?    @relation(fields: [partId], references: [id], onDelete: SetNull)
  partId      Int?
  service     Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  serviceId   Int?
}

enum Side {
  LEFT
  RIGHT
  OTHER
}

model Employee {
  id          Int          @id @default(autoincrement())
  zkUserId    String       @unique
  name        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attendances Attendance[]
}

model Attendance {
  id          Int            @id @default(autoincrement())
  type        AttendanceType
  statusLabel String
  scannedAt   DateTime
  notifiedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  employee    Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId  Int

  @@index([employeeId, scannedAt])
}

// บันทึกว่าข้อความประจำวันแบบไหนส่งไปแล้ว — กันส่งซ้ำแม้ worker restart
// และให้ข้อความที่พลาดตามเวลา (เช่น เน็ตหลุด) ถูกส่งย้อนหลังได้ในวันเดียวกัน
model DailyNotice {
  id      Int             @id @default(autoincrement())
  dateKey String // YYYY-MM-DD (เวลาไทย)
  kind    DailyNoticeKind
  sentAt  DateTime        @default(now())

  @@unique([dateKey, kind])
}

enum DailyNoticeKind {
  DAY_START
  ALL_CLOCKED_IN
  DAILY_SUMMARY
}

enum AttendanceType {
  CLOCK_IN
  CLOCK_IN_LATE
  LUNCH_OUT
  LUNCH_RETURN
  LUNCH_RETURN_LATE
  CLOCK_OUT
}
